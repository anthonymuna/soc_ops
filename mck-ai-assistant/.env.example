# Methodist Church Kenya AI Assistant - Environment Configuration

# Project Name
PROJECT_NAME="Methodist Church Kenya AI Assistant"

# Database Configuration
# Default is SQLite file in the root directory.
# For production PostgreSQL: postgresql://username:password@hostname:5432/dbname
DATABASE_URL="sqlite:///./methodist_church.db"

# Google Gemini API Key
# Provide your Gemini API key from Google AI Studio to enable live cloud LLM & Embedding RAG.
# If left empty, the application runs in a local pseudo-RAG simulation mode (great for offline dry-runs).
GEMINI_API_KEY=""

# Security configuration (JWT signature key)
SECRET_KEY="supersecretkeyforchurchaiassistant-changemeinproduction"
ACCESS_TOKEN_EXPIRE_MINUTES=1440
